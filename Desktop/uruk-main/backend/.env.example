# Copy this file to .env and fill in real values. Never commit .env.

# ── Server ──
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ── Database (MySQL) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=uruk_admin
DB_PASSWORD=CHANGE_ME
DB_NAME=uruk_motors

# ── JWT (mobile users) ──
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=30d

# ── JWT (admin dashboard employees) ──
ADMIN_JWT_SECRET=CHANGE_ME_WITH_A_DIFFERENT_LONG_RANDOM_STRING
ADMIN_JWT_EXPIRES_IN=8h

# ── Twilio Verify (for real SMS OTP) ──
# Leave empty to use the dev-mode bypass (any 6-digit code works).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── File Upload ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Production-only: comma-separated list of allowed origins for CORS ──
# ALLOWED_ORIGINS=https://urukmotors.iq,https://www.urukmotors.iq
